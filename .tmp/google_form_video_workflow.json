      "id": "8705cda3-5d3d-4b2e-951d-32a0a435635e",
      "name": "Update Sheet with Video",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.4,
      "position": [
        2220,
        200
      ],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "1",
          "name": "Google Sheets account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Check timeout (max 3 minutes for D-ID)\nconst startTime = $('Extract Talk ID').first().json.timestamp || Date.now();\nconst elapsed = Date.now() - new Date(startTime).getTime();\nconst maxWait = 3 * 60 * 1000; // 3 minutes\n\nif (elapsed > maxWait) {\n  throw new Error('Video generation timeout - exceeded 3 minutes');\n}\n\n// Pass data back\nreturn [{\n  json: {\n    talk_id: $('Extract Talk ID').first().json.talk_id,\n    status: 'processing',\n    product_name: $('Extract Talk ID').first().json.product_name,\n    generated_script: $('Extract Talk ID').first().json.generated_script,\n    row_number: $('Extract Talk ID').first().json.row_number\n  }\n}];"
      },
      "id": "55e7b722-1181-4d39-b447-c619780c29f8",
      "name": "Still Processing",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2220,
        400
      ]
    }
  ],
