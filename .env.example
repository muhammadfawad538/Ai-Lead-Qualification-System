# API Keys and Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================
# LEAD ENRICHMENT WORKFLOW - REQUIRED APIs
# ============================================

# Google Gemini API (FREE - Unlimited)
# Get it from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Google Custom Search API (FREE - 100 queries/day)
# Step 1: Create project at https://console.cloud.google.com
# Step 2: Enable Custom Search API
# Step 3: Create credentials (API Key)
GOOGLE_SEARCH_API_KEY=your_google_search_api_key_here

# Google Custom Search Engine ID
# Create at: https://programmablesearchengine.google.com/
# Make sure to enable "Search the entire web"
GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id_here

# ============================================
# OPTIONAL APIs (Free Tier)
# ============================================

# Wappalyzer API (FREE - 50 lookups/month)
# Get it from: https://www.wappalyzer.com/api/
# Note: If not provided, workflow will use web scraping fallback
WAPPALYZER_API_KEY=your_wappalyzer_api_key_here

# AbstractAPI Email Validation (FREE - 100/month)
# Get it from: https://www.abstractapi.com/api/email-verification-validation-api
# Note: If not provided, workflow will use regex + DNS validation
ABSTRACTAPI_KEY=your_abstractapi_key_here

# ============================================
# Google Sheets Configuration
# ============================================

# Your Google Sheet ID (from the URL)
# Example: https://docs.google.com/spreadsheets/d/SHEET_ID_HERE/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# ============================================
# Workflow Configuration
# ============================================

# Your product/service value proposition (for email generation)
VALUE_PROPOSITION="We help SaaS companies automate their sales process and increase conversion rates by 40%"

# Your company name
COMPANY_NAME="Your Company Name"

# Contact email for generated outreach
CONTACT_EMAIL="sales@yourcompany.com"

# ============================================
# n8n Configuration (if managing n8n instances)
# ============================================
# N8N_API_KEY=your_n8n_api_key
# N8N_BASE_URL=https://your-n8n-instance.com
